{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "docker-compose": {
    "fileMatch": ["(^|/)docker-compose\\.yaml$"]
  },
  "hostRules": [
    {
      "hostType": "docker",
      "matchHost": "ghcr.io",
      "username": "",
      "password": ""
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "ghcr.io/andygodish/electrs", 
        "ghcr.io/andygodish/bitcoin-knots"
      ],
      "enabled": true
    }
  ]
}